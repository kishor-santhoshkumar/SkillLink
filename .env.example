# Database Configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/skilllink

# Application Configuration
APP_ENV=development

# Groq AI Configuration
GROQ_API_KEY=your_groq_api_key_here

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Google OAuth (Optional - for Google Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id-from-console.apps.googleusercontent.com

# n8n Webhook Configuration (for email notifications and automation)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/skilllink
